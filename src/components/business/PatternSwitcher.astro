---
/**
 * デザインパターン切替バー（比較・レビュー用の一時的スカフォールド）。
 * A 編集紙面 / B システム / C 対比 の3案を1クリックで行き来できる。
 * 採用パターン確定後にこのコンポーネントは撤去する想定。
 */
import { patterns } from '../../lib/businessContent';

interface Props {
  /** 現在表示中のパターン id（'a' | 'b' | 'c'） */
  readonly current: 'a' | 'b' | 'c';
}
const { current } = Astro.props;
---

<div
  class="fixed inset-x-0 bottom-4 z-[70] flex justify-center px-4 print:hidden"
  aria-label="デザインパターン切替（比較用）"
>
  <div class="flex items-center gap-1 border border-ink-300 bg-page/95 p-1.5 shadow-lg backdrop-blur">
    <span class="font-serif-en px-2 text-[9px] uppercase tracking-[0.2em] text-ink-400">
      Design
    </span>
    {
      patterns.map((p) => {
        const active = p.id === current;
        return (
          <a
            href={p.href}
            aria-current={active ? 'page' : undefined}
            class={`font-gothic px-3 py-1.5 text-xs font-semibold tracking-[0.02em] transition ${
              active
                ? 'bg-brand text-white'
                : 'text-ink-600 hover:bg-ink-50 hover:text-ink-900'
            }`}
          >
            {p.id.toUpperCase()}. {p.label}
            <span class="ml-1 hidden font-serif-en text-[9px] uppercase tracking-[0.15em] opacity-60 sm:inline">
              {p.en}
            </span>
          </a>
        );
      })
    }
  </div>
</div>
