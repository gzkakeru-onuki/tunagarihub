---
/**
 * ビジネス / 連携ページ — 案B「システム / Systemic」
 *
 * 明るいヒーロー＋中央の連携ダイアグラム（HUB＋Geek → シンクロ率エンジン → 最適マッチング）。
 * 構造化された枠組み・図解中心で、AIプロダクト的だが editorial の骨格を保つ方向性。
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PatternSwitcher from '../components/business/PatternSwitcher.astro';
import { links } from '../lib/links';
import { orgs, bridges, fields, syncAxes, philosophy, media } from '../lib/businessContent';
---

<BaseLayout
  title="ビジネス（案B）｜TSUNAGARI HUB × aisou（株式会社Geek）"
  description="TSUNAGARI HUB × aisou（株式会社Geek提供）の連携ページ・デザイン案B（システム）。"
>
  <Header />
  <main>
    {/* ===================== Hero（明るい・図解中心） ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 md:col-span-9">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">
            Business / Partnership
            <span class="mx-2 text-ink-300">/</span>
            <span class="font-mincho normal-case tracking-[0.14em] text-ink-700">TSUNAGARI HUB × aisou</span>
          </p>
          <h1 class="font-mincho mt-6 leading-[1.12] tracking-tight text-ink-900" style="font-size: clamp(38px, 5.6vw, 76px);">
            出会いを、<span class="text-brand">設計</span>する。
          </h1>
          <p class="font-gothic mt-8 max-w-2xl text-[15px] leading-[1.95] text-ink-600">
            コミュニティが生む「信頼」と、AIが導く「シンクロ率」。二つの入力を掛け合わせ、
            相性・価値観・目的の合う出会いを、仕組みとして生み出します。
          </p>
        </div>

        {/* 連携ダイアグラム */}
        <div class="col-span-12 mt-14 border border-ink-200 bg-page p-4 sm:p-8 md:mt-16">
          <p class="font-serif-en mb-4 text-[10px] uppercase tracking-[0.28em] text-ink-400">
            System / 連携の仕組み
          </p>
          <svg
            viewBox="0 0 1000 380"
            class="sync-svg h-auto w-full"
            role="img"
            aria-label="TSUNAGARI HUB の信頼と aisou（株式会社Geek提供）のAIが、シンクロ率エンジン（相性・価値観・目的）を介して最適なマッチング・チームビルディングを生み出す連携図"
          >
            {/* connectors */}
            <g fill="none" stroke-width="1.5">
              <path class="edge" d="M280 110 C 360 110, 360 190, 425 190" stroke="rgb(var(--primary) / 0.6)" />
              <path class="edge" d="M280 270 C 360 270, 360 190, 425 190" stroke="rgb(var(--accent-deep) / 0.6)" />
              <line class="edge" x1="615" y1="190" x2="748" y2="190" stroke="rgb(var(--primary) / 0.6)" />
            </g>

            {/* input: HUB */}
            <g>
              <rect x="40" y="66" width="242" height="88" fill="rgb(var(--primary) / 0.06)" stroke="rgb(var(--primary))" stroke-width="1.25" />
              <text x="60" y="102" class="font-mincho" style="font-size:19px;font-weight:700;" fill="rgb(var(--editorial-rule-color))">TSUNAGARI HUB</text>
              <text x="60" y="128" class="font-gothic" style="font-size:13px;" fill="rgb(var(--editorial-rule-color))">コミュニティ・信頼</text>
            </g>
            {/* input: Geek */}
            <g>
              <rect x="40" y="226" width="242" height="88" fill="rgb(var(--accent-deep) / 0.06)" stroke="rgb(var(--accent-deep))" stroke-width="1.25" />
              <text x="60" y="258" class="font-mincho" style="font-size:20px;font-weight:700;" fill="rgb(var(--editorial-rule-color))">aisou</text>
              <text x="60" y="284" class="font-gothic" style="font-size:12px;" fill="rgb(var(--editorial-rule-color))">株式会社Geek 提供 ・ AI</text>
            </g>

            {/* engine */}
            <circle cx="520" cy="190" r="96" fill="rgb(var(--primary) / 0.08)" stroke="rgb(var(--primary))" stroke-width="1.5" />
            <text x="520" y="176" text-anchor="middle" class="font-mincho" style="font-size:22px;font-weight:700;" fill="rgb(var(--primary-deep))">シンクロ率</text>
            <text x="520" y="204" text-anchor="middle" class="font-serif-en" style="font-size:10px;letter-spacing:0.16em;" fill="rgb(var(--primary))">ENGINE</text>
            <text x="520" y="232" text-anchor="middle" class="font-gothic" style="font-size:12px;" fill="rgb(var(--editorial-rule-color))">相性 ・ 価値観 ・ 目的</text>

            {/* output */}
            <g>
              <rect x="750" y="146" width="210" height="88" fill="none" stroke="rgb(var(--editorial-rule-color) / 0.6)" stroke-width="1.25" />
              <text x="770" y="182" class="font-mincho" style="font-size:18px;font-weight:700;" fill="rgb(var(--editorial-rule-color))">最適な出会い</text>
              <text x="770" y="208" class="font-gothic" style="font-size:13px;" fill="rgb(var(--editorial-rule-color))">マッチング・チーム</text>
            </g>
          </svg>
        </div>

        <div class="col-span-12 mt-10 flex flex-col gap-4 sm:flex-row md:col-start-1">
          <a href={links.consult} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 bg-brand px-8 py-4 text-sm font-semibold text-white shadow-md shadow-brand/20 transition hover:bg-brand-dark sm:text-base">
            連携・相談する
          </a>
          <a href={links.aiMatching} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 border border-ink-300 px-8 py-4 text-sm font-semibold text-ink-800 transition hover:border-ink-800 hover:bg-ink-50 sm:text-base">
            aisou（AI人材マッチング）を見る
          </a>
        </div>
      </div>
    </section>

    {/* ===================== 両者：構造化パネル ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Partners / 二つの入力</p>
          <h2 class="font-mincho mt-6 leading-[1.2] tracking-tight text-ink-900">二つの力を、ひとつの仕組みに。</h2>
        </div>

        <div class="col-span-12 mt-14 grid grid-cols-1 gap-6 md:mt-20 md:grid-cols-2">
          {
            orgs.map((org, idx) => (
              <article class="flex flex-col border border-ink-200 bg-page p-8 sm:p-10">
                <figure class="editorial-photo mb-7" style="aspect-ratio: 16 / 9;">
                  <img src={org.img} alt="" aria-hidden="true" loading="lazy" style="height: 100%; object-fit: cover;" />
                </figure>
                <div class="flex items-center justify-between">
                  <p class="font-serif-en text-[11px] uppercase tracking-[0.28em] text-brand">{String(idx + 1).padStart(2, '0')} / {org.en}</p>
                  <span class="editorial-mark text-[11px] text-ink-500" aria-hidden="true">{org.key === 'hub' ? '人' : 'AI'}</span>
                </div>
                <hr class="editorial-rule-double mt-5" aria-hidden="true" />
                <h3 class="font-mincho mt-6 text-2xl tracking-tight text-ink-900 sm:text-3xl">{org.name}</h3>
                <p class="font-serif-en mt-2 text-[12px] tracking-[0.1em] text-ink-400">{org.sub}</p>
                <p class="font-gothic mt-4 text-[14px] font-semibold text-brand">{org.role}</p>
                <p class="font-gothic mt-4 flex-1 text-[15px] leading-[1.9] text-ink-700">{org.body}</p>
                <ul class="mt-6 flex list-none flex-col gap-2.5 border-t border-ink-100 p-0 pt-6">
                  {org.points.map((pt) => (
                    <li class="font-gothic flex items-start gap-3 text-[14px] leading-[1.7] text-ink-700">
                      <span class="font-serif-en mt-0.5 shrink-0 text-[11px] text-brand" aria-hidden="true">→</span>
                      <span>{pt}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===================== 連携価値：横並びシステム ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 md:col-span-9">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Output / 生み出すつながり</p>
          <h2 class="font-mincho mt-6 leading-[1.2] tracking-tight text-ink-900">仕組みが生む、3つのつながり。</h2>
        </div>

        <div class="col-span-12 mt-14 grid grid-cols-1 gap-0 border-t border-ink-200 md:mt-20 md:grid-cols-3">
          {
            bridges.map((b, idx) => (
              <div class={`border-ink-200 py-10 md:px-8 ${idx > 0 ? 'border-t md:border-l md:border-t-0' : 'md:pl-0'}`}>
                <p class="font-serif-en text-[40px] leading-none text-ink-200" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</p>
                <p class="font-serif-en mt-5 text-[11px] uppercase tracking-[0.24em] text-brand">{b.en}</p>
                <h3 class="font-mincho mt-3 text-xl tracking-tight text-ink-900 sm:text-2xl">{b.title}</h3>
                <p class="font-gothic mt-4 text-[14px] leading-[1.85] text-ink-700">{b.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===================== シンクロ率メカニズム ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 border border-ink-200 bg-tint/40 p-8 transition-colors duration-500 sm:p-12 md:p-16">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Synchronization Rate / シンクロ率</p>
          <h2 class="font-mincho mt-6 leading-[1.3] tracking-tight text-ink-900">AIが測る、3つの一致度。</h2>
          <p class="font-gothic mt-6 max-w-2xl text-[15px] leading-[1.9] text-ink-700">
            シンクロ率は、3つの軸で出会いの一致度を測ります。採用だけでなく、あらゆる分野で最適なチームビルディングを可能にし、新たな共創とイノベーションの種になります。
          </p>

          <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-3">
            {
              syncAxes.map((axis, i) => (
                <div>
                  <div class="flex items-baseline justify-between">
                    <span class="font-mincho text-xl text-ink-900">{axis}</span>
                    <span class="font-serif-en text-[11px] tracking-[0.18em] text-ink-400">0{i + 1}</span>
                  </div>
                  <div class="mt-3 h-1.5 w-full bg-ink-200">
                    <div class="h-full bg-brand" style={`width: ${[88, 82, 92][i]}%`}></div>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="mt-10 flex flex-wrap gap-3 border-t border-ink-200 pt-8">
            {
              fields.map((f) => (
                <span class="font-gothic border border-ink-300 px-4 py-1.5 text-[13px] tracking-[0.04em] text-ink-700">{f}</span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {/* ===================== CTA ===================== */}
    <section
      class="editorial-section relative overflow-hidden bg-surface-dark bg-cover bg-center py-section-y text-white transition-colors duration-500"
      style={`background-image: linear-gradient(rgb(var(--surface-dark) / 0.9), rgb(var(--surface-dark) / 0.94)), url('${media.ctaBg}');`}
    >
      <div class="editorial-grid relative">
        <div class="col-span-12 md:col-span-9">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-white/55">Get Started / まずは、つながる</p>
          <h2 class="font-mincho mt-6 leading-[1.2] tracking-tight text-white">あなたに合う出会いを、AIとともに。</h2>
          <p class="font-gothic mt-6 max-w-2xl text-[15px] leading-[1.9] text-white/80">
            採用・人材をお探しの企業の方も、新しい出会いを求める個人の方も。まずはお気軽にご相談ください。
          </p>
        </div>
        <div class="col-span-12 mt-10 flex flex-col gap-4 sm:flex-row md:col-start-1">
          <a href={links.consult} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 bg-gold px-8 py-4 text-sm font-semibold text-white transition hover:bg-gold-deep sm:text-base">
            お問い合わせ・相談する
          </a>
          <a href={links.aiMatching} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 border border-white/35 px-8 py-4 text-sm font-semibold text-white transition hover:border-white/70 hover:bg-white/5 sm:text-base">
            aisou（AI人材マッチングサービス）へ
          </a>
        </div>
      </div>
    </section>

    {/* ===================== 他AI企業との連携 ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 md:col-start-2 md:col-span-10">
          <hr class="editorial-rule-brush mb-12 w-32" aria-hidden="true" />
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Open Collaboration / 共に創る仲間へ</p>
          <h2 class="font-mincho mt-6 text-3xl leading-[1.3] tracking-tight text-ink-900 sm:text-4xl md:text-5xl">AIの力で、より良い未来を共に。</h2>
          <p class="font-gothic mt-8 max-w-2xl text-[15px] leading-[1.95] text-ink-700">{philosophy.lead}</p>
          <p class="font-mincho mt-16 text-2xl leading-[1.6] tracking-tight text-ink-900 sm:text-3xl">{philosophy.close}</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <PatternSwitcher current="b" />
</BaseLayout>

<style>
  .sync-svg .edge { stroke-dasharray: 320; stroke-dashoffset: 320; }
  .sync-svg.is-drawn .edge { animation: sync-draw 1s ease forwards; }
  @keyframes sync-draw { to { stroke-dashoffset: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .sync-svg .edge { stroke-dashoffset: 0; animation: none; }
  }
</style>

<script>
  (function () {
    var svgs = document.querySelectorAll('.sync-svg');
    if (!svgs.length) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('IntersectionObserver' in window)) {
      svgs.forEach(function (s) { s.classList.add('is-drawn'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-drawn'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.3 });
    svgs.forEach(function (s) { io.observe(s); });
  })();
</script>
