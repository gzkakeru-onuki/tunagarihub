---
/**
 * ビジネス / 連携ページ — 案C「対比 / Split（Duality）」
 *
 * 二者を左右のトーン対比（コミュニティの温かさ × AIのクールさ）で見せ、
 * 中央の「×」で交わり、ひとつの価値へ収束していく方向性。高コントラスト・対称。
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PatternSwitcher from '../components/business/PatternSwitcher.astro';
import { links } from '../lib/links';
import { orgs, bridges, fields, philosophy, media } from '../lib/businessContent';

const hub = orgs.find((o) => o.key === 'hub')!;
const geek = orgs.find((o) => o.key === 'geek')!;
---

<BaseLayout
  title="ビジネス（案C）｜TSUNAGARI HUB × aisou（株式会社Geek）"
  description="TSUNAGARI HUB × aisou（株式会社Geek提供）の連携ページ・デザイン案C（対比スプリット）。"
>
  <Header />
  <main>
    {/* ===================== Split Hero ===================== */}
    <section class="relative grid grid-cols-1 md:grid-cols-2">
      {/* 左：TSUNAGARI HUB（温） */}
      <div class="relative flex min-h-[440px] flex-col justify-center overflow-hidden bg-tint px-6 py-20 transition-colors duration-500 sm:px-10 md:min-h-[580px] md:px-14 md:py-32 lg:px-20">
        <img
          src="/images/business/community-group.jpg"
          alt=""
          aria-hidden="true"
          loading="eager"
          class="absolute inset-0 h-full w-full object-cover object-center"
          style="filter: grayscale(0.35) contrast(1.04);"
        />
        <div class="absolute inset-0 bg-tint/85 transition-colors duration-500" aria-hidden="true"></div>
        <div class="relative z-10">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Community</p>
          <h2 class="font-mincho mt-5 text-4xl leading-[1.15] tracking-tight text-ink-900 sm:text-5xl">
            {hub.name}
          </h2>
          <p class="font-gothic mt-4 text-[14px] font-semibold text-brand">{hub.role}</p>
          <p class="font-mincho mt-8 text-2xl tracking-[0.08em] text-ink-900 sm:text-3xl">人 ・ 信頼 ・ 出会い</p>
          <p class="font-gothic mt-6 max-w-md text-[14px] leading-[1.9] text-ink-700">{hub.body}</p>
        </div>
      </div>

      {/* 右：株式会社Geek（冷） */}
      <div class="relative flex min-h-[440px] flex-col justify-center overflow-hidden bg-surface-dark px-6 py-20 text-white transition-colors duration-500 sm:px-10 md:min-h-[580px] md:px-14 md:py-32 lg:px-20">
        <img
          src="/images/business/network-globe.jpg"
          alt=""
          aria-hidden="true"
          loading="eager"
          class="absolute inset-0 h-full w-full object-cover object-center"
          style="filter: grayscale(0.2) contrast(1.05);"
        />
        <div class="absolute inset-0 bg-surface-dark/85 transition-colors duration-500" aria-hidden="true"></div>
        <div class="relative z-10">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-gold-soft">AI Technology</p>
          <h2 class="font-mincho mt-5 text-4xl leading-[1.15] tracking-tight text-white sm:text-5xl">
            {geek.name}
          </h2>
          <p class="font-gothic mt-2 text-[12px] tracking-[0.1em] text-white/60">{geek.sub}</p>
          <p class="font-gothic mt-4 text-[14px] font-semibold text-gold-soft">{geek.role}</p>
          <p class="font-mincho mt-8 text-2xl tracking-[0.08em] text-white/90 sm:text-3xl">AI ・ データ ・ 精度</p>
          <p class="font-gothic mt-6 max-w-md text-[14px] leading-[1.9] text-white/80">{geek.body}</p>
        </div>
      </div>

      {/* 中央シーム「×」 */}
      <div
        class="pointer-events-none absolute left-1/2 top-1/2 z-10 hidden h-16 w-16 -translate-x-1/2 -translate-y-1/2 items-center justify-center border border-ink-300 bg-page md:flex"
        aria-hidden="true"
      >
        <span class="font-mincho text-2xl text-ink-800">×</span>
      </div>
    </section>

    {/* ===================== 収束：ユニファイング・ステートメント ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 md:col-span-10 md:col-start-2">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Business / Partnership</p>
          <h1 class="font-mincho mt-6 leading-[1.12] tracking-tight text-ink-900" style="font-size: clamp(38px, 5.8vw, 80px);">
            <span class="text-brand">人</span> × <span class="text-brand">AI</span> で、<br class="sm:hidden" />出会いを再発明する。
          </h1>
          <p class="font-gothic mt-8 max-w-2xl text-[15px] leading-[1.95] text-ink-600">
            コミュニティの温かさと、AIの知性。相反するように見える二つが交わるとき、
            人と人・人と企業・人とAIをつなぐ、新しい共創のかたちが生まれます。
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href={links.consult} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 bg-brand px-8 py-4 text-sm font-semibold text-white shadow-md shadow-brand/20 transition hover:bg-brand-dark sm:text-base">
              連携・相談する
            </a>
            <a href={links.aiMatching} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 border border-ink-300 px-8 py-4 text-sm font-semibold text-ink-800 transition hover:border-ink-800 hover:bg-ink-50 sm:text-base">
              aisou（AI人材マッチング）を見る
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== 融合の価値（3つのつなぐ・中央対称） ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 text-center md:col-span-8 md:col-start-3">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Synergy / 交わりが生む価値</p>
          <h2 class="font-mincho mt-6 leading-[1.2] tracking-tight text-ink-900">交わると、価値が生まれる。</h2>
        </div>

        <div class="col-span-12 mt-14 grid grid-cols-1 gap-10 md:mt-20 md:grid-cols-3">
          {
            bridges.map((b) => (
              <div class="flex flex-col items-center border-t-2 border-brand/30 pt-8 text-center">
                <figure class="editorial-photo mb-7 w-full" style="aspect-ratio: 3 / 2;">
                  <img src={b.img} alt="" aria-hidden="true" loading="lazy" style="height: 100%; object-fit: cover;" />
                </figure>
                <p class="font-serif-en text-[11px] uppercase tracking-[0.24em] text-brand">{b.en}</p>
                <h3 class="font-mincho mt-4 text-2xl tracking-tight text-ink-900 sm:text-[28px]">{b.title}</h3>
                <p class="font-gothic mt-5 max-w-xs text-[14px] leading-[1.85] text-ink-700">{b.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===================== シンクロ率（ダークブロック） ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div
          class="col-span-12 bg-surface-dark bg-cover bg-center p-10 text-center text-white transition-colors duration-500 sm:p-14 md:p-20"
          style={`background-image: linear-gradient(rgb(var(--surface-dark) / 0.88), rgb(var(--surface-dark) / 0.93)), url('${media.network}');`}
        >
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-white/55">Synchronization Rate / シンクロ率</p>
          <h2 class="font-mincho mx-auto mt-6 max-w-3xl text-3xl leading-[1.4] sm:text-4xl md:text-5xl">
            AIが高める、出会いの<span class="text-gold-soft">「シンクロ率」</span>。
          </h2>
          <p class="font-gothic mx-auto mt-8 max-w-2xl text-[15px] leading-[1.95] text-white/80">
            相性・価値観・目的のシンクロ率が高いマッチングは、採用だけにとどまりません。あらゆる分野で最適なチームビルディングを可能にし、新たな共創とイノベーションを数多く生み出すきっかけになります。
          </p>
          <div class="mt-10 flex flex-wrap justify-center gap-3">
            {
              fields.map((f) => (
                <span class="font-gothic border border-white/30 px-4 py-1.5 text-[13px] tracking-[0.04em] text-white/85">{f}</span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {/* ===================== CTA ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 text-center md:col-span-8 md:col-start-3">
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Get Started / まずは、つながる</p>
          <h2 class="font-mincho mt-6 leading-[1.2] tracking-tight text-ink-900">あなたに合う出会いを、AIとともに。</h2>
          <p class="font-gothic mx-auto mt-8 max-w-2xl text-[15px] leading-[1.9] text-ink-600">
            採用・人材をお探しの企業の方も、新しい出会いを求める個人の方も。まずはお気軽にご相談ください。
          </p>
          <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
            <a href={links.consult} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 bg-brand px-8 py-4 text-sm font-semibold text-white shadow-md shadow-brand/20 transition hover:bg-brand-dark sm:text-base">
              お問い合わせ・相談する
            </a>
            <a href={links.aiMatching} target="_blank" rel="noopener noreferrer" class="font-gothic inline-flex items-center justify-center gap-2 border border-ink-300 px-8 py-4 text-sm font-semibold text-ink-800 transition hover:border-ink-800 hover:bg-ink-50 sm:text-base">
              aisou（AI人材マッチングサービス）へ
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== 他AI企業との連携 ===================== */}
    <section class="editorial-section relative overflow-hidden bg-page transition-colors duration-500">
      <div class="editorial-grid relative">
        <div class="col-span-12 text-center md:col-start-2 md:col-span-10">
          <hr class="editorial-rule-brush mx-auto mb-12 w-32" aria-hidden="true" />
          <p class="font-serif-en text-[11px] uppercase tracking-[0.32em] text-brand">Open Collaboration / 共に創る仲間へ</p>
          <h2 class="font-mincho mt-6 text-3xl leading-[1.3] tracking-tight text-ink-900 sm:text-4xl md:text-5xl">AIの力で、より良い未来を共に。</h2>
          <p class="font-gothic mx-auto mt-8 max-w-2xl text-[15px] leading-[1.95] text-ink-700">{philosophy.lead}</p>
          <p class="font-mincho mt-16 text-2xl leading-[1.6] tracking-tight text-ink-900 sm:text-3xl md:text-[34px]">{philosophy.close}</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <PatternSwitcher current="c" />
</BaseLayout>
